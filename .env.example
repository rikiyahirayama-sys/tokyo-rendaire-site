# Environment Variables
# Copy this file to .env.local and fill in the values

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Google Calendar
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxxxx@xxxxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=xxxxx@group.calendar.google.com

# WhatsApp Business API (Meta)
WHATSAPP_API_TOKEN=xxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxxx
WHATSAPP_VERIFY_TOKEN=xxxxx

# WeChat Official Account
WECHAT_APP_ID=xxxxx
WECHAT_APP_SECRET=xxxxx
WECHAT_TOKEN=xxxxx

# Notifications (Owner)
OWNER_PHONE_NUMBER=+81xxxxxxxxxx
OWNER_EMAIL=owner@example.com

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=MAISON ROUGE
